# AURORA — Environment Configuration
# Copy to .env and fill in all values

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=aurora
POSTGRES_PASSWORD=change_me_32_chars_min
POSTGRES_DB=aurora
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@aurora-db:5432/${POSTGRES_DB}

# ─── Backend ──────────────────────────────────────────────────
APP_PORT=3000
METRICS_PORT=3001
FRONT_END_DOMAIN=http://localhost:3000
PANEL_DOMAIN=http://localhost:3000
SUB_PUBLIC_DOMAIN=http://localhost:3000

# ─── Security ─────────────────────────────────────────────────
JWT_AUTH_SECRET=change_me_min_32_chars_long_secret_key_here
JWT_AUTH_LIFETIME=12
JWT_API_TOKENS_SECRET=change_me_another_min_32_chars_secret
PASSWORD_HMAC_SECRET=change_me_yet_another_32_chars

# ─── Valkey / Redis ──────────────────────────────────────────
REDIS_SOCKET=/var/run/valkey/valkey.sock
REDIS_DB=1

# ─── Documentation ───────────────────────────────────────────
IS_DOCS_ENABLED=true
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
METRICS_USER=aurora
METRICS_PASS=change_me

# ─── Logging ──────────────────────────────────────────────────
IS_HTTP_LOGGING_ENABLED=false
ENABLE_DEBUG_LOGS=false
