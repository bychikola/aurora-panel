# ═══════════════════════════════════════════════════════════════
# AURORA — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=aurora
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aurora
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@aurora-db:5432/${POSTGRES_DB}

# ─── Backend ──────────────────────────────────────────────────
APP_PORT=3000
METRICS_PORT=3001
FRONT_END_DOMAIN=https://your-domain.com
PANEL_DOMAIN=https://your-domain.com
SUB_PUBLIC_DOMAIN=https://your-domain.com

# ─── JWT & Security ──────────────────────────────────────────
JWT_AUTH_SECRET=change_me_min_32_chars_long_secret_key_here
JWT_AUTH_LIFETIME=12
JWT_API_TOKENS_SECRET=change_me_another_min_32_chars_long_secret
PASSWORD_HMAC_SECRET=change_me_yet_another_32_chars_secret_key

# ─── Redis / Valkey ──────────────────────────────────────────
REDIS_SOCKET=/var/run/valkey/valkey.sock
# Or use TCP:
# REDIS_HOST=aurora-redis
# REDIS_PORT=6379
REDIS_DB=1

# ─── API Documentation ────────────────────────────────────────
IS_DOCS_ENABLED=true
SWAGGER_PATH=/docs
SCALAR_PATH=/scalar
METRICS_USER=aurora
METRICS_PASS=change_me_metrics_password

# ─── Telegram Notifications ──────────────────────────────────
IS_TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_ROOT=https://api.telegram.org
# TELEGRAM_BOT_PROXY=http://proxy:8080
TELEGRAM_NOTIFY_USERS=
TELEGRAM_NOTIFY_NODES=
TELEGRAM_NOTIFY_CRM=
TELEGRAM_NOTIFY_SERVICE=
TELEGRAM_NOTIFY_TBLOCKER=

# ─── Webhook ─────────────────────────────────────────────────
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_SECRET_HEADER=

# ─── Performance ──────────────────────────────────────────────
SHORT_UUID_LENGTH=16
IS_HTTP_LOGGING_ENABLED=false
ENABLE_DEBUG_LOGS=false

# ─── Service Settings ─────────────────────────────────────────
SERVICE_CLEAN_USAGE_HISTORY=true
SERVICE_DISABLE_USER_USAGE_RECORDS=false

# ─── Bandwidth Notifications ─────────────────────────────────
BANDWIDTH_USAGE_NOTIFICATIONS_ENABLED=false
# BANDWIDTH_USAGE_NOTIFICATIONS_THRESHOLD=[50,75,90,95]

NOT_CONNECTED_USERS_NOTIFICATIONS_ENABLED=false
# NOT_CONNECTED_USERS_NOTIFICATIONS_AFTER_HOURS=[24,48,72]

USER_USAGE_IGNORE_BELOW_BYTES=0
